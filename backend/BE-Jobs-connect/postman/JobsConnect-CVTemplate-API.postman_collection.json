              ]
            },
            "description": "Lấy danh sách tất cả templates với pagination (Admin only). Bao gồm cả active và inactive templates."
          },
          "response": []
        },
        {
          "name": "Get Template By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
