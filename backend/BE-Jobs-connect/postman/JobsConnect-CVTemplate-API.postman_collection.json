            ],
            "url": {
              "raw": "{{base_url}}/api/cv-templates?page=1&limit=10&isActive=true",
              "host": ["{{base_url}}"],
              "path": ["api", "cv-templates"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "isActive",
                  "value": "true",
                  "description": "Filter by active status",
                  "disabled": true
