                  "disabled": true
                },
                {
                  "key": "htmlUrl",
                  "value": "",
                  "type": "text",
                  "description": "New HTML URL (optional - can upload file instead)",
                  "disabled": true
                },
                {
                  "key": "preview",
                  "type": "file",
                  "src": [],
                  "description": "New preview image file (optional - will update previewUrl)",
                  "disabled": true
                },
                {
                  "key": "previewUrl",
                  "value": "",
                  "type": "text",
                  "description": "New preview image URL (optional - can upload file instead)",
                  "disabled": true
                },
                {
                  "key": "isActive",
                  "value": "true",
                  "type": "text",
                  "description": "Is template active (optional)"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/cv-templates/{{template_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "cv-templates", "{{template_id}}"]
