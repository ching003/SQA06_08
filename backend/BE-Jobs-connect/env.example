# Server Configuration
PORT=4000
NODE_ENV=development

# JWT Configuration
# Generate a secure secret key using: npm run generate:jwt-secret
# Or use OpenSSL: openssl rand -base64 64
# Minimum recommended length: 32 bytes (256 bits)
# Production: Use at least 64 bytes (512 bits)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Database Configuration (Prisma)
DATABASE_URL="postgresql://postgres:1234@localhost:5432/jobsconnect?schema=public"

# Firebase Configuration (Admin SDK)
# Lưu ý: Backend sử dụng Firebase Admin SDK, không cần apiKey, authDomain, etc.
# Chỉ cần Project ID, Database URL và Storage Bucket là đủ cho hầu hết các tính năng

# Firebase Project ID (từ config)
FIREBASE_PROJECT_ID=jobsconnect-dafde

# Firebase Realtime Database URL (từ config)
FIREBASE_DATABASE_URL=https://jobsconnect-dafde-default-rtdb.asia-southeast1.firebasedatabase.app

# Firebase Storage Bucket (từ config)
FIREBASE_STORAGE_BUCKET=jobsconnect-dafde.firebasestorage.app

# Option 1: Sử dụng Service Account (Recommended cho production)
# Để upload files và các tính năng nâng cao, cần Service Account
# Tải Service Account Key từ: Firebase Console > Project Settings > Service Accounts
# FIREBASE_CLIENT_EMAIL=your-service-account-email@jobsconnect-dafde.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
# 
# Lưu ý khi copy private key vào .env:
# - Giữ nguyên format với \n (newline)
# - Hoặc dùng format một dòng với \\n (sẽ được tự động convert)
# - Ví dụ: FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Option 2: Không có Service Account (Chỉ dùng Database và Storage cơ bản)
# Nếu không set FIREBASE_CLIENT_EMAIL và FIREBASE_PRIVATE_KEY,
# Firebase sẽ sử dụng Application Default Credentials hoặc chạy với quyền hạn hạn chế

