{
  "info": {
    "_postman_id": "jobsconnect-user-api-001",
    "name": "JobsConnect - User API",
    "description": "Collection cho các API User của JobsConnect Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data) {",
                  "        pm.environment.set(\"user_id\", response.data.id);",
                  "        pm.environment.set(\"user_email\", response.data.email);",
                  "        console.log(\"✅ User registered successfully\");",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"{{test_password}}\",\n    \"fullName\": \"Test User\",\n    \"role\": \"CANDIDATE\",\n    \"phoneNumber\": \"0123456789\",\n    \"gender\": \"MALE\",\n    \"dateOfBirth\": \"1990-01-01\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/register",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "register"]
            },
            "description": "Đăng ký user mới"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data && response.data.token) {",
                  "        // Lưu token vào environment variable",
                  "        pm.environment.set(\"auth_token\", response.data.token);",
                  "        pm.environment.set(\"user_id\", response.data.user.id);",
                  "        pm.environment.set(\"user_email\", response.data.user.email);",
                  "        pm.environment.set(\"user_role\", response.data.user.role);",
                  "        ",
                  "        console.log(\"✅ Login successful\");",
                  "        console.log(\"Token saved to environment variable\");",
                  "        console.log(\"User ID: \" + response.data.user.id);",
                  "    }",
                  "} else {",
                  "    console.log(\"❌ Login failed: \" + pm.response.text());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/login",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "login"]
            },
            "description": "Đăng nhập và nhận JWT token. Token sẽ tự động được lưu vào biến môi trường."
          },
          "response": []
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data && response.data.token) {",
                  "        // Lưu token vào environment variable",
                  "        pm.environment.set(\"auth_token\", response.data.token);",
                  "        pm.environment.set(\"admin_token\", response.data.token); // Cũng lưu vào admin_token để tiện test",
                  "        pm.environment.set(\"user_id\", response.data.user.id);",
                  "        pm.environment.set(\"user_email\", response.data.user.email);",
                  "        pm.environment.set(\"user_role\", response.data.user.role);",
                  "        ",
                  "        console.log(\"✅ Admin login successful\");",
                  "        console.log(\"Token saved to auth_token and admin_token\");",
                  "    }",
                  "} else {",
                  "    console.log(\"❌ Admin login failed: \" + pm.response.text());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{admin_email}}\",\n    \"password\": \"{{admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/login",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "login"]
            },
            "description": "Đăng nhập với admin account. Token sẽ được lưu vào cả auth_token và admin_token. Lưu ý: Backend chỉ check role trong token, không phân biệt tên biến. Nếu user là ADMIN, auth_token có thể dùng cho tất cả APIs."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "logout"]
            },
            "description": "Đăng xuất (client-side token removal)"
          },
          "response": []
        }
      ],
      "description": "Các API authentication (public)"
    },
