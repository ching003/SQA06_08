  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-refresh token nếu hết hạn",
          "const token = pm.environment.get(\"auth_token\");",
          "if (token) {",
          "    try {",
          "        // Decode JWT để check expiry (không verify signature)",
          "        const payload = JSON.parse(atob(token.split('.')[1]));",
          "        const exp = payload.exp * 1000; // Convert to milliseconds",
          "        const now = Date.now();",
          "        ",
          "        // Nếu token sắp hết hạn trong 5 phút tới, tự động login lại",
          "        if (exp - now < 5 * 60 * 1000) {",
          "            console.log(\"⚠️ Token sắp hết hạn, tự động refresh...\");",
          "            ",
          "            // Gọi login API để lấy token mới",
          "            pm.sendRequest({",
          "                url: pm.environment.get(\"base_url\") + \"/api/users/login\",",
          "                method: 'POST',",
          "                header: {",
          "                    'Content-Type': 'application/json'",
          "                },",
          "                body: {",
          "                    mode: 'raw',",
          "                    raw: JSON.stringify({",
          "                        email: pm.environment.get(\"test_email\"),",
          "                        password: pm.environment.get(\"test_password\")",
          "                    })",
          "                }",
          "            }, function (err, res) {",
          "                if (!err && res.code === 200) {",
          "                    const response = res.json();",
          "                    if (response.success && response.data && response.data.token) {",
          "                        pm.environment.set(\"auth_token\", response.data.token);",
          "                        console.log(\"✅ Token đã được refresh tự động\");",
          "                    }",
          "                }",
          "            });",
          "        }",
          "    } catch (e) {",
          "        console.log(\"⚠️ Không thể check token expiry: \" + e.message);",
          "    }",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test script",
          "pm.test(\"Response time is less than 5000ms\", function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "// Check response format",
          "if (pm.response.code !== 204) {",
          "    try {",
          "        const jsonData = pm.response.json();",
          "        pm.test(\"Response has success field\", function () {",
          "            pm.expect(jsonData).to.have.property('success');",
          "        });",
          "    } catch (e) {",
          "        // Not JSON response, skip",
          "    }",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4000",
      "type": "string"
    }
  ]
