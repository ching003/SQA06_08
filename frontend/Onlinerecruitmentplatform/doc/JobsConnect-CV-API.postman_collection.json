  "item": [
    {
      "name": "CV Management",
      "item": [
        {
          "name": "Create CV",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has success field\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('success');",
                  "    pm.expect(response.success).to.be.true;",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data) {",
                  "        pm.environment.set(\"cv_id\", response.data.id);",
                  "        if (response.data.templateId) {",
                  "            pm.environment.set(\"cv_template_id\", response.data.templateId);",
                  "        }",
                  "        if (response.data.template) {",
                  "            console.log(\"Template: \" + response.data.template.name);",
                  "        }",
                  "        console.log(\"✅ CV created successfully\");",
                  "        console.log(\"CV ID: \" + response.data.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"My Professional CV\",\n    \"fullName\": \"Nguyen Van A\",\n    \"email\": \"{{user_email}}\",\n    \"phoneNumber\": \"0123456789\",\n    \"dateOfBirth\": \"1990-01-01\",\n    \"gender\": \"MALE\",\n    \"address\": \"123 Main Street, Ho Chi Minh City\",\n    \"currentPosition\": \"Senior Software Engineer\",\n    \"summary\": \"Experienced software engineer with 5+ years of experience in web development.\",\n    \"objective\": \"Seeking a challenging position in software development.\",\n    \"isOpenForJob\": true,\n    \"templateId\": \"{{template_id}}\",\n    \"educations\": [\n        {\n            \"institution\": \"Ho Chi Minh University of Technology\",\n            \"degree\": \"Bachelor of Computer Science\",\n            \"startDate\": \"2010-09-01\",\n            \"endDate\": \"2014-06-30\",\n            \"description\": \"Graduated with honors\"\n        }\n    ],\n    \"workExperiences\": [\n        {\n            \"title\": \"Senior Software Engineer\",\n            \"company\": \"Tech Corp\",\n            \"startDate\": \"2019-01-01\",\n            \"endDate\": null,\n            \"description\": \"Lead development of web applications using Node.js and React\"\n        },\n        {\n            \"title\": \"Software Engineer\",\n            \"company\": \"StartupXYZ\",\n            \"startDate\": \"2016-06-01\",\n            \"endDate\": \"2018-12-31\",\n            \"description\": \"Developed and maintained RESTful APIs\"\n        }\n    ],\n    \"skills\": [\n        {\n            \"skillName\": \"JavaScript\",\n            \"level\": \"EXPERT\",\n            \"yearsOfExperience\": 5\n        },\n        {\n            \"skillName\": \"Node.js\",\n            \"level\": \"ADVANCED\",\n            \"yearsOfExperience\": 4\n        },\n        {\n            \"skillName\": \"React\",\n            \"level\": \"ADVANCED\",\n            \"yearsOfExperience\": 3\n        }\n    ],\n    \"projects\": [\n        {\n            \"name\": \"E-commerce Platform\",\n            \"description\": \"Full-stack e-commerce application\",\n            \"startDate\": \"2020-01-01\",\n            \"endDate\": \"2020-06-30\",\n            \"url\": \"https://example.com/project\",\n            \"role\": \"Full-stack Developer\"\n        }\n    ],\n    \"certifications\": [\n        {\n            \"name\": \"AWS Certified Developer\",\n            \"issuer\": \"Amazon Web Services\",\n            \"acquiredAt\": \"2021-03-15\",\n            \"description\": \"Associate level certification\"\n        }\n    ],\n    \"languages\": [\n        {\n            \"name\": \"English\",\n            \"level\": \"ADVANCED\",\n            \"description\": \"Fluent in speaking and writing\"\n        },\n        {\n            \"name\": \"Vietnamese\",\n            \"level\": \"NATIVE\",\n            \"description\": \"Native speaker\"\n        }\n    ],\n    \"achievements\": [\n        {\n            \"title\": \"Best Employee of the Year\",\n            \"description\": \"Awarded for outstanding performance\",\n            \"acquiredAt\": \"2022-12-31\"\n        }\n    ],\n    \"activities\": [\n        {\n            \"title\": \"Open Source Contributor\",\n            \"organization\": \"GitHub Community\",\n            \"startDate\": \"2018-01-01\",\n            \"endDate\": null,\n            \"description\": \"Contributed to various open source projects\"\n        }\n    ],\n    \"references\": [\n        {\n            \"name\": \"John Doe\",\n            \"position\": \"CTO\",\n            \"company\": \"Tech Corp\",\n            \"description\": \"Former manager\"\n        }\n    ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/cvs",
              "host": ["{{base_url}}"],
              "path": ["api", "cvs"]
            },
            "description": "Tạo CV mới với đầy đủ thông tin. Có thể chỉ định templateId để liên kết CV với CV Template (optional)."
          },
          "response": []
        },
        {
          "name": "Get CV By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has success field\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('success');",
                  "    pm.expect(response.success).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Response has CV data\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data).to.have.property('id');",
                  "    pm.expect(response.data).to.have.property('title');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data) {",
                  "        if (response.data.templateId) {",
                  "            pm.environment.set(\"cv_template_id\", response.data.templateId);",
                  "            console.log(\"Template ID: \" + response.data.templateId);",
                  "        }",
                  "        if (response.data.template) {",
                  "            console.log(\"Template: \" + response.data.template.name);",
                  "            console.log(\"Template HTML URL: \" + response.data.template.htmlUrl);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
